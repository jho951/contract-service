SERVICE_SHARED_NETWORK=service-backbone-shared

PROMETHEUS_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/prod-monitoring-service-prometheus:replace-with-git-sha
GRAFANA_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/prod-monitoring-service-grafana:replace-with-git-sha
LOKI_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/prod-monitoring-service-loki:replace-with-git-sha
PROMTAIL_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/prod-monitoring-service-promtail:replace-with-git-sha

PROMETHEUS_BIND_HOST=127.0.0.1
PROMETHEUS_PORT=9090
GRAFANA_BIND_HOST=127.0.0.1
GRAFANA_PORT=3005
LOKI_BIND_HOST=127.0.0.1
LOKI_PORT=3100

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-grafana-admin-password

PROMETHEUS_RETENTION_TIME=7d
LOKI_RETENTION_PERIOD=168h
