SERVICE_SHARED_NETWORK=service-backbone-shared
BACKEND_SHARED_NETWORK=service-backbone-shared
MSA_SHARED_NETWORK=service-backbone-shared

AUTHZ_SERVICE_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/prod-authz-service:replace-with-git-sha

AUTHZ_SERVICE_HOST_BIND=127.0.0.1
AUTHZ_SERVICE_HOST_PORT=8084

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8084

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT_MS=1000ms

AUTHZ_INTERNAL_JWT_SECRET=replace-with-authz-caller-proof-secret
AUTHZ_INTERNAL_JWT_ISSUER=api-gateway
AUTHZ_INTERNAL_JWT_AUDIENCE=authz-service

PERMISSION_INTERNAL_REQUEST_SECRET=replace-with-shared-internal-secret

PLATFORM_SECURITY_JWT_SECRET=replace-with-gateway-downstream-shared-secret
PLATFORM_SECURITY_JWT_ISSUER=api-gateway
PLATFORM_SECURITY_JWT_AUDIENCE=internal-services
PLATFORM_SECURITY_INTERNAL_ALLOW_CIDRS=127.0.0.1/32,172.16.0.0/12,10.0.0.0/8,192.168.0.0/16
