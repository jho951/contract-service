SERVICE_SHARED_NETWORK=service-backbone-shared
BACKEND_SHARED_NETWORK=service-backbone-shared
MSA_SHARED_NETWORK=service-backbone-shared

GATEWAY_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/prod-gateway-service:replace-with-git-sha

GATEWAY_HOST_BIND=0.0.0.0
GATEWAY_HOST_PORT=8080

APP_ENV=prod
APP_ENV_FILE=/app/.env.prod
GATEWAY_BIND=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_REQUEST_TIMEOUT_MS=30000

AUTH_SERVICE_URL=http://auth-service:8081
AUTH_SERVICE_INTERNAL_REQUEST_SECRET=replace-with-auth-caller-proof-secret
USER_SERVICE_URL=http://user-service:8082
EDITOR_SERVICE_URL=http://editor-service:8083
AUTHZ_ADMIN_VERIFY_URL=http://authz-service:8084/permissions/internal/admin/verify

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT_MS=1000

GATEWAY_INTERNAL_JWT_SHARED_SECRET=replace-with-gateway-downstream-shared-secret
GATEWAY_INTERNAL_JWT_ISSUER=api-gateway
GATEWAY_INTERNAL_JWT_AUDIENCE=internal-services
GATEWAY_INTERNAL_JWT_TTL_SECONDS=300

GATEWAY_INTERNAL_REQUEST_SECRET=replace-with-shared-internal-secret

AUTHZ_INTERNAL_JWT_SECRET=replace-with-authz-caller-proof-secret
AUTHZ_INTERNAL_JWT_ISSUER=api-gateway
AUTHZ_INTERNAL_JWT_AUDIENCE=authz-service
AUTHZ_INTERNAL_JWT_TTL_SECONDS=300

GATEWAY_SESSION_CACHE_ENABLED=true
GATEWAY_SESSION_LOCAL_CACHE_TTL_SECONDS=3
GATEWAY_SESSION_CACHE_TTL_SECONDS=60
GATEWAY_SESSION_CACHE_KEY_PREFIX=gateway:session:

GATEWAY_AUTHZ_CACHE_ENABLED=false
GATEWAY_AUTHZ_CACHE_TTL_SECONDS=300
GATEWAY_AUTHZ_CACHE_PREFIX=gateway:admin-authz:

GATEWAY_CORS_ALLOWED_ORIGINS=*
