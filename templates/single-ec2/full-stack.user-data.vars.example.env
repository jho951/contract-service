deploy_user="ec2-user"
base_dir="/opt/services"
network_name="service-backbone-shared"

contract_repo_url="https://github.com/example-org/service-contract.git"
contract_repo_ref="main"
include_monitoring="true"

gateway_repo_url="https://github.com/example-org/gateway-service.git"
gateway_repo_ref="main"
auth_repo_url="https://github.com/example-org/auth-service.git"
auth_repo_ref="main"
user_repo_url="https://github.com/example-org/user-service.git"
user_repo_ref="main"
authz_repo_url="https://github.com/example-org/authz-service.git"
authz_repo_ref="main"
editor_repo_url="https://github.com/example-org/editor-service.git"
editor_repo_ref="main"
redis_repo_url="https://github.com/example-org/redis-service.git"
redis_repo_ref="main"
monitoring_repo_url="https://github.com/example-org/monitoring-service.git"
monitoring_repo_ref="main"

gateway_env_file="templates/single-ec2/env/gateway-service.env.prod.example"
auth_env_file="templates/single-ec2/env/auth-service.env.prod.example"
user_env_file="templates/single-ec2/env/user-service.env.prod.example"
authz_env_file="templates/single-ec2/env/authz-service.env.prod.example"
editor_env_file="templates/single-ec2/env/editor-service.env.prod.example"
redis_env_file="templates/single-ec2/env/redis-service.env.prod.example"
monitoring_env_file="templates/single-ec2/env/monitoring-service.env.prod.example"
